{
  "info": {
    "name": "DANMA API",
    "description": "Coleccion completa de endpoints para el proyecto DANMA - Bullet Hell Arena.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{token}}", "type": "string" }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "Session ID obtenido al hacer Login. Se llena automaticamente."
    },
    {
      "key": "userId",
      "value": "",
      "type": "string",
      "description": "ID del usuario autenticado. Se llena automaticamente al hacer Login."
    },
    {
      "key": "room_id",
      "value": "",
      "type": "string",
      "description": "UUID de sala. Se llena automaticamente al crear una sala."
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"TestPlayer\",\n  \"email\": \"test@danma.gg\",\n  \"password\": \"secret123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Registra un nuevo usuario. No requiere autenticacion."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    console.log('[DANMA] token guardado:', json.token);",
                  "}",
                  "if (json.userId) {",
                  "    pm.collectionVariables.set('userId', json.userId);",
                  "    console.log('[DANMA] userId guardado:', json.userId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@danma.gg\",\n  \"password\": \"secret123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Autentica al usuario. Guarda automaticamente {{token}} y {{userId}} para el resto de la coleccion."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "logout"]
            },
            "description": "Invalida la sesion activa. Requiere autenticacion (usa {{token}} heredado)."
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "me"]
            },
            "description": "Devuelve la informacion del usuario autenticado."
          }
        },
        {
          "name": "Get All Users (debug)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/auth",
              "host": ["{{base_url}}"],
              "path": ["api", "auth"]
            },
            "description": "Lista todos los usuarios. Endpoint de desarrollo, no requiere auth."
          }
        }
      ]
    },
    {
      "name": "Users / Friends",
      "item": [
        {
          "name": "Send Friend Request",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users/2/friend-request",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "2", "friend-request"]
            },
            "description": "Envia una solicitud de amistad al usuario con el ID indicado en la URL."
          }
        },
        {
          "name": "Get Pending Friend Requests",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users/{{userId}}/friend-requests",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "{{userId}}", "friend-requests"]
            },
            "description": "Devuelve las solicitudes de amistad pendientes del usuario autenticado."
          }
        },
        {
          "name": "Accept Friend Request",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users/friend-requests/1/accept",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "friend-requests", "1", "accept"]
            },
            "description": "Acepta la solicitud de amistad con el ID indicado."
          }
        }
      ]
    },
    {
      "name": "Rooms",
      "description": "Endpoints para gestion de salas efimeras (Redis, TTL 2h). Todos los que modifican estado requieren auth heredada de la coleccion.",
      "item": [
        {
          "name": "Create Room",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.id) {",
                  "    pm.collectionVariables.set('room_id', json.id);",
                  "    console.log('[DANMA] room_id guardado:', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/rooms",
              "host": ["{{base_url}}"],
              "path": ["api", "rooms"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sala de prueba\",\n  \"map\": \"classic\",\n  \"maxPlayers\": 4,\n  \"isPublic\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Crea una sala efimera. Respuesta 201 con objeto sala. Guarda {{room_id}} automaticamente.\n\nCampos: name (3-30), map, maxPlayers (2-20), password (opcional), isPublic, difficulty (normal|difficult|no_mercy)."
          }
        },
        {
          "name": "Create Room (with password)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/rooms",
              "host": ["{{base_url}}"],
              "path": ["api", "rooms"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sala privada\",\n  \"map\": \"desert\",\n  \"maxPlayers\": 2,\n  \"password\": \"1234\",\n  \"isPublic\": false\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Crea una sala privada con contrasena. No aparece en el listado publico."
          }
        },
        {
          "name": "List Public Rooms",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/rooms",
              "host": ["{{base_url}}"],
              "path": ["api", "rooms"]
            },
            "description": "Devuelve hasta 50 salas publicas sin contrasena, ordenadas por mas reciente."
          }
        },
        {
          "name": "Get Room by ID",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/rooms/{{room_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "rooms", "{{room_id}}"]
            },
            "description": "Devuelve detalles de una sala por UUID. Incluye players[] y playersCount."
          }
        },
        {
          "name": "Join Room",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/rooms/{{room_id}}/join",
              "host": ["{{base_url}}"],
              "path": ["api", "rooms", "{{room_id}}", "join"]
            },
            "body": {
              "mode": "raw",
              "raw": "{}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Une al usuario autenticado a la sala. Sale automaticamente de su sala anterior si estaba en una.\n\nDevuelve { room } con players[] y playersCount actualizados.\n\nErrores: 400 eres el host, 403 contrasena incorrecta, 404 no encontrada, 409 sala llena."
          }
        },
        {
          "name": "Join Room (with password)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/rooms/{{room_id}}/join",
              "host": ["{{base_url}}"],
              "path": ["api", "rooms", "{{room_id}}", "join"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"1234\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Igual que Join Room pero con contrasena para salas privadas."
          }
        },
        {
          "name": "Leave Room",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/rooms/{{room_id}}/join",
              "host": ["{{base_url}}"],
              "path": ["api", "rooms", "{{room_id}}", "join"]
            },
            "description": "Sale de la sala. Remueve al usuario del players[] y actualiza playersCount.\n\nEl host no puede usar este endpoint — debe borrar la sala con DELETE /rooms/:roomId.\n\nErrores: 400 eres el host, 404 sala no encontrada."
          }
        },
        {
          "name": "Delete Room",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/rooms/{{room_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "rooms", "{{room_id}}"]
            },
            "description": "Elimina la sala. Solo puede hacerlo el host.\n\nErrores: 400 roomId invalido, 403 no es el host, 404 no encontrada."
          }
        }
      ]
    }
  ]
}