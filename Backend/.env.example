# ---- Servidor ----
PORT=8080
HOST=0.0.0.0
NODE_ENV=development

# ---- Base de datos (SQLite) ----
# Ruta al archivo .db. Por defecto: data/danmakrew.db (relativo a Backend/)
DB_PATH=./data/danmakrew.db

# ---- Mailer (Nodemailer / Gmail) ----
# Usa un correo de Gmail y una "Contraseña de Aplicación" de 16 caracteres
EMAIL_USER=justanexamplemail@gmail.com
EMAIL_PASS=just_an_example_password

# ---- Frontend ----
FRONTEND_URL=http://localhost:3000
# ---- Frontend URL (Para los enlaces de verificación) ----
# En desarrollo usa ngrok, en producción usa tu dominio real
FRONTEND_URL=https://jet-linseed-unbent.ngrok-free.dev/

# ---- Redis (Opcional - Próxima implementación) ----
# REDIS_URL=redis://default:tu_contraseña@tu_endpoint_redis:puerto
