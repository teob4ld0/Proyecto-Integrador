# ---- Servidor ----
PORT=8080

# ---- Base de datos (PostgreSQL local o Neon en la nube) ----
DB_HOST=tu-host-de-neon.aws.neon.tech
DB_PORT=5432
DB_NAME=nombre_de_la_base_de_datos
DB_USER=usuario_de_la_base
DB_PASSWORD=tu_contrasena_secreta

# ---- JWT (JSON Web Tokens para el Login) ----
JWT_KEY=CambiaEstaPorUnaClaveSecreta
JWT_ISSUER=DanmakrewAPI
JWT_AUDIENCE=DanmakrewUsers

# ---- Mailer (Nodemailer / Gmail) ----
# Usa un correo de Gmail y una "Contraseña de Aplicación" de 16 caracteres
EMAIL_USER=tu-correo@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx

# ---- Frontend URL (Para los enlaces de verificación) ----
# En desarrollo usa ngrok, en producción usa tu dominio real
FRONTEND_URL=https://tu-url-de-ngrok.ngrok-free.dev

# ---- Redis (Opcional - Próxima implementación) ----
# REDIS_URL=redis://default:tu_contraseña@tu_endpoint_redis:puerto
